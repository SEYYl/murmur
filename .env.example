# ─── Murmur 环境变量配置模板 ───
# 复制本文件为 .env 并填入真实值后使用。
# .env 已在 .gitignore 中，不会被提交。

# ─── 安全（必填） ───
# JWT 签名密钥，用于生成和验证用户登录 token。
# 生产环境必须设置为随机长字符串（建议 32+ 字符）。
# 可用命令生成：python -c "import secrets; print(secrets.token_urlsafe(32))"
# 如未设置，服务启动时会生成临时随机密钥，但重启后所有已登录用户需重新登录。
ASMR_SECRET_KEY=

# ─── CORS 跨域（按需修改） ───
# 允许的前端来源，逗号分隔。
# 本地开发默认：http://127.0.0.1:8000,http://localhost:8000
# 生产部署改为你的域名，如：https://murmur.example.com
ASMR_CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# ─── 对象存储（可选，默认使用本地磁盘） ───
# 将存储后端切换为 S3 时填写以下变量。
# 支持 AWS S3、Cloudflare R2、MinIO 等兼容 S3 协议的服务。

# 存储后端：local（默认）或 s3
MURMUR_STORAGE_BACKEND=local

# S3 提供商：custom（默认）、aws、cloudflare-r2
MURMUR_STORAGE_PROVIDER=custom

# S3 区域
MURMUR_S3_REGION=

# S3 桶名
MURMUR_S3_BUCKET=

# S3 访问密钥
MURMUR_S3_ACCESS_KEY=

# S3 秘密密钥
MURMUR_S3_SECRET_KEY=

# S3 端点（Cloudflare R2 / MinIO 等需填写，AWS S3 可留空）
# R2 示例：https://<account_id>.r2.cloudflarestorage.com
MURMUR_S3_ENDPOINT=
